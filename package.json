{
  "name": "iobroker.ultrahuman",
  "version": "0.1.3",
  "description": "ioBroker adapter for Ultrahuman Ring health metrics",
  "author": {
    "name": "SmarterPapa",
    "email": "email@smarterpapa.de"
  },
  "homepage": "https://github.com/SmarterPapa/ioBroker.ultrahuman",
  "license": "MIT",
  "keywords": [
    "ioBroker",
    "ultrahuman",
    "health",
    "sleep",
    "heart-rate",
    "hrv",
    "ring",
    "wearable"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/SmarterPapa/ioBroker.ultrahuman.git"
  },
  "engines": {
    "node": ">= 20"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.3.2",
    "axios": "^1.7.9"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.1.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.1.2",
    "@alcalzone/release-script-plugin-license": "^5.1.1",
    "@alcalzone/release-script-plugin-manual-review": "^5.1.1",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/testing": "^5.2.2",
    "@types/node": "^22.10.5",
    "@types/proxyquire": "^1.3.31",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.19.1",
    "eslint": "^8.57.1",
    "proxyquire": "^2.1.3",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.7.3"
  },
  "main": "build/main.js",
  "files": [
    "admin/",
    "build/",
    "io-package.json",
    "LICENSE"
  ],
  "scripts": {
    "prebuild": "rimraf build",
    "build": "tsc -p tsconfig.build.json",
    "watch": "tsc -p tsconfig.build.json --watch",
    "test:unit": "mocha --config test/.mocharc.yml",
    "test:package": "mocha test/package --exit",
    "test:integration": "mocha test/integration --exit",
    "test": "npm run test:unit",
    "lint": "eslint --ext .ts src/",
    "translate": "echo 'no translate script'",
    "release": "release-script"
  }
}
