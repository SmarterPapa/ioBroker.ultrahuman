{
  "name": "iobroker.ultrahuman",
  "version": "0.1.0",
  "description": "ioBroker adapter for Ultrahuman Ring health metrics",
  "author": {
    "name": "Tobias"
  },
  "homepage": "https://github.com/SmarterPapa/ioBroker.ultrahuman",
  "license": "MIT",
  "keywords": [
    "ioBroker",
    "ultrahuman",
    "health",
    "sleep",
    "heart-rate",
    "hrv",
    "ring",
    "wearable"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/SmarterPapa/ioBroker.ultrahuman.git"
  },
  "engines": {
    "node": ">= 18"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.2.3",
    "axios": "^1.7.9"
  },
  "devDependencies": {
    "@iobroker/testing": "^5.0.0",
    "@types/chai": "^4.3.20",
    "@types/chai-as-promised": "^7.1.8",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.10.5",
    "@types/proxyquire": "^1.3.31",
    "@types/sinon": "^17.0.3",
    "@types/sinon-chai": "^3.2.12",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "chai": "^4.5.0",
    "chai-as-promised": "^7.1.2",
    "eslint": "^8.57.1",
    "mocha": "^10.8.2",
    "proxyquire": "^2.1.3",
    "rimraf": "^6.0.1",
    "sinon": "^19.0.2",
    "sinon-chai": "^3.7.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.7.3"
  },
  "main": "build/main.js",
  "files": [
    "admin/",
    "build/",
    "io-package.json",
    "LICENSE"
  ],
  "scripts": {
    "prebuild": "rimraf build",
    "build": "tsc -p tsconfig.build.json",
    "watch": "tsc -p tsconfig.build.json --watch",
    "test:unit": "mocha --config test/.mocharc.yml",
    "test:package": "mocha test/package --exit",
    "test:integration": "mocha test/integration --exit",
    "test": "npm run test:unit",
    "lint": "eslint --ext .ts src/",
    "translate": "echo 'no translate script'",
    "release": "echo 'no release script'"
  }
}
