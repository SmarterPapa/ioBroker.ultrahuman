{
  "i18n": true,
  "type": "tabs",
  "items": {
    "_generalTab": {
      "type": "panel",
      "label": {
        "en": "Authentication",
        "de": "Authentifizierung"
      },
      "items": {
        "_introHeader": {
          "type": "header",
          "text": {
            "en": "Connect your Ultrahuman Ring",
            "de": "Verbinde deinen Ultrahuman Ring"
          },
          "size": 4,
          "newLine": true
        },
        "_introText": {
          "type": "staticText",
          "newLine": true,
          "style": { "marginBottom": "16px" },
          "text": {
            "en": "This adapter reads health data from your Ultrahuman Ring via the Partner API. You need API credentials from the **ultrahuman-dashboard** project or directly from Ultrahuman.",
            "de": "Dieser Adapter liest Gesundheitsdaten von deinem Ultrahuman Ring über die Partner API. Du benötigst API-Zugangsdaten vom **ultrahuman-dashboard** Projekt oder direkt von Ultrahuman."
          }
        },
        "authMode": {
          "type": "select",
          "label": {
            "en": "Authentication mode",
            "de": "Authentifizierungsmodus"
          },
          "sm": 12,
          "md": 6,
          "newLine": true,
          "options": [
            { "label": { "en": "API Key (recommended)", "de": "API-Schlüssel (empfohlen)" }, "value": "apikey" },
            { "label": { "en": "OAuth 2.0 (for developers)", "de": "OAuth 2.0 (für Entwickler)" }, "value": "oauth" }
          ],
          "default": "apikey",
          "help": {
            "en": "Most users should use API Key mode. OAuth 2.0 is for advanced setups with custom Ultrahuman partner credentials.",
            "de": "Die meisten Nutzer sollten den API-Schlüssel-Modus verwenden. OAuth 2.0 ist für fortgeschrittene Setups mit eigenen Ultrahuman Partner-Zugangsdaten."
          }
        },
        "_divider0": {
          "type": "divider",
          "newLine": true
        },
        "_apikeyPanel": {
          "type": "panel",
          "hidden": "data.authMode === 'oauth'",
          "items": {
            "_apikeyHeader": {
              "type": "header",
              "text": {
                "en": "API Key Settings",
                "de": "API-Schlüssel Einstellungen"
              },
              "size": 5,
              "newLine": true
            },
            "_howToGetCredentials": {
              "type": "staticText",
              "newLine": true,
              "style": { "marginBottom": "16px" },
              "text": {
                "en": "**How to get your credentials:**\n\n1. Send an email to **feedback@ultrahuman.com** and request API access for personal use\n2. You will receive an **API Key** and an **Access Code**\n3. Enter the **Access Code** in your Ultrahuman app (Profile → Settings → Partner ID)\n4. Enter the **API Key** and your **Ultrahuman email** below",
                "de": "**So erhältst du deine Zugangsdaten:**\n\n1. Schreibe eine E-Mail an **feedback@ultrahuman.com** und frage nach API-Zugang für persönliche Nutzung\n2. Du erhältst einen **API-Schlüssel** und einen **Access Code**\n3. Gib den **Access Code** in deiner Ultrahuman-App ein (Profil → Einstellungen → Partner ID)\n4. Trage den **API-Schlüssel** und deine **Ultrahuman E-Mail** unten ein"
              }
            },
            "apiSecret": {
              "type": "text",
              "label": {
                "en": "API Key (ULTRAHUMAN_API_KEY)",
                "de": "API-Schlüssel (ULTRAHUMAN_API_KEY)"
              },
              "sm": 12,
              "md": 6,
              "newLine": true,
              "placeholder": {
                "en": "Paste your API key here",
                "de": "Füge deinen API-Schlüssel hier ein"
              },
              "help": {
                "en": "The authorization key from your ultrahuman-dashboard .env file or from Ultrahuman directly",
                "de": "Der Autorisierungsschlüssel aus deiner ultrahuman-dashboard .env Datei oder direkt von Ultrahuman"
              }
            },
            "userEmail": {
              "type": "text",
              "label": {
                "en": "Ultrahuman Email (ULTRAHUMAN_EMAIL)",
                "de": "Ultrahuman E-Mail (ULTRAHUMAN_EMAIL)"
              },
              "sm": 12,
              "md": 6,
              "placeholder": "your-email@example.com",
              "help": {
                "en": "The email address linked to your Ultrahuman account",
                "de": "Die E-Mail-Adresse, die mit deinem Ultrahuman-Konto verknüpft ist"
              }
            },
            "_accessCodeHint": {
              "type": "staticText",
              "newLine": true,
              "style": { "marginTop": "16px", "padding": "12px", "backgroundColor": "rgba(255, 193, 7, 0.1)", "borderRadius": "8px", "borderLeft": "4px solid #ffc107" },
              "text": {
                "en": "**Important:** The Access Code must be entered in your Ultrahuman app under **Profile → Settings → Partner ID**. Without this, the API cannot access your data. You received this code together with your API key.",
                "de": "**Wichtig:** Der Access Code muss in deiner Ultrahuman-App unter **Profil → Einstellungen → Partner ID** eingegeben werden. Ohne diesen kann die API nicht auf deine Daten zugreifen. Du hast diesen Code zusammen mit deinem API-Schlüssel erhalten."
              }
            }
          }
        },
        "_oauthPanel": {
          "type": "panel",
          "hidden": "data.authMode !== 'oauth'",
          "items": {
            "_oauthHeader": {
              "type": "header",
              "text": {
                "en": "OAuth 2.0 Settings",
                "de": "OAuth 2.0 Einstellungen"
              },
              "size": 5,
              "newLine": true
            },
            "_oauthExplanation": {
              "type": "staticText",
              "newLine": true,
              "style": { "marginBottom": "16px" },
              "text": {
                "en": "**OAuth 2.0 is for advanced users** who have registered as an Ultrahuman Partner and received their own Client ID and Client Secret.\n\nWith OAuth, each user can log in with their own Ultrahuman account – no shared API key needed.\n\nTo become a partner, apply at [Ultrahuman Partnerships](https://partnerships.ultrahuman.com/).",
                "de": "**OAuth 2.0 ist für fortgeschrittene Nutzer**, die sich als Ultrahuman Partner registriert und eigene Client ID und Client Secret erhalten haben.\n\nMit OAuth kann sich jeder Nutzer mit seinem eigenen Ultrahuman-Konto anmelden – kein geteilter API-Schlüssel nötig.\n\nUm Partner zu werden, bewirb dich bei [Ultrahuman Partnerships](https://partnerships.ultrahuman.com/)."
              }
            },
            "clientId": {
              "type": "text",
              "label": {
                "en": "Client ID",
                "de": "Client ID"
              },
              "sm": 12,
              "md": 6,
              "newLine": true,
              "help": {
                "en": "OAuth Client ID from Ultrahuman partner onboarding",
                "de": "OAuth Client ID aus dem Ultrahuman Partner-Onboarding"
              }
            },
            "clientSecret": {
              "type": "text",
              "label": {
                "en": "Client Secret",
                "de": "Client Secret"
              },
              "sm": 12,
              "md": 6,
              "help": {
                "en": "OAuth Client Secret from Ultrahuman partner onboarding",
                "de": "OAuth Client Secret aus dem Ultrahuman Partner-Onboarding"
              }
            },
            "oauthCallbackPort": {
              "type": "number",
              "label": {
                "en": "Callback Port",
                "de": "Callback Port"
              },
              "sm": 12,
              "md": 3,
              "newLine": true,
              "min": 1024,
              "max": 65535,
              "default": 8890,
              "help": {
                "en": "Local port for the OAuth callback server (default: 8890). Make sure this port is not blocked by a firewall.",
                "de": "Lokaler Port für den OAuth-Callback-Server (Standard: 8890). Stelle sicher, dass dieser Port nicht von einer Firewall blockiert wird."
              }
            },
            "_loginButton": {
              "type": "sendTo",
              "label": {
                "en": "Login with Ultrahuman",
                "de": "Mit Ultrahuman anmelden"
              },
              "sm": 12,
              "md": 4,
              "newLine": true,
              "command": "startOAuth",
              "variant": "contained",
              "color": "primary",
              "data": {},
              "openUrl": true,
              "jsonData": "{}",
              "help": {
                "en": "Opens the Ultrahuman login page. After authorization, you will be redirected back automatically.",
                "de": "Öffnet die Ultrahuman-Anmeldeseite. Nach der Autorisierung wirst du automatisch weitergeleitet."
              }
            },
            "_tokenStatus": {
              "type": "staticText",
              "newLine": true,
              "style": { "marginTop": "16px" },
              "text": {
                "en": "**Token status:** Check the adapter log for authentication status. Tokens are automatically refreshed when they expire.",
                "de": "**Token-Status:** Prüfe das Adapter-Log für den Authentifizierungsstatus. Tokens werden automatisch erneuert, wenn sie ablaufen."
              }
            }
          }
        }
      }
    },
    "_settingsTab": {
      "type": "panel",
      "label": {
        "en": "Settings",
        "de": "Einstellungen"
      },
      "items": {
        "_settingsHeader": {
          "type": "header",
          "text": {
            "en": "Polling Settings",
            "de": "Abfrage-Einstellungen"
          },
          "size": 5,
          "newLine": true
        },
        "_settingsExplanation": {
          "type": "staticText",
          "newLine": true,
          "style": { "marginBottom": "16px" },
          "text": {
            "en": "The Ultrahuman Ring syncs data periodically to the cloud (not in real-time). Polling too frequently wastes resources and may trigger rate limits.",
            "de": "Der Ultrahuman Ring synchronisiert Daten periodisch in die Cloud (nicht in Echtzeit). Zu häufiges Abfragen verschwendet Ressourcen und kann Rate-Limits auslösen."
          }
        },
        "pollingInterval": {
          "type": "number",
          "label": {
            "en": "Polling Interval (minutes)",
            "de": "Abfrageintervall (Minuten)"
          },
          "sm": 12,
          "md": 4,
          "min": 5,
          "max": 1440,
          "default": 30,
          "help": {
            "en": "How often to fetch new data from the API. Recommended: 30 minutes.",
            "de": "Wie oft neue Daten von der API abgerufen werden. Empfohlen: 30 Minuten."
          }
        },
        "_intervalHint": {
          "type": "staticText",
          "newLine": true,
          "style": { "marginTop": "8px" },
          "text": {
            "en": "**Recommended:** 30 minutes | **Minimum:** 5 minutes | **Maximum:** 1440 minutes (24 hours)",
            "de": "**Empfohlen:** 30 Minuten | **Minimum:** 5 Minuten | **Maximum:** 1440 Minuten (24 Stunden)"
          }
        }
      }
    },
    "_aboutTab": {
      "type": "panel",
      "label": {
        "en": "About",
        "de": "Über"
      },
      "items": {
        "_logoContainer": {
          "type": "staticImage",
          "src": "smarterpapa-logo.png",
          "newLine": true,
          "style": { "width": "120px", "height": "120px", "marginBottom": "16px" }
        },
        "_aboutHeader": {
          "type": "header",
          "text": {
            "en": "About this Adapter",
            "de": "Über diesen Adapter"
          },
          "size": 5,
          "newLine": true
        },
        "_aboutText": {
          "type": "staticText",
          "newLine": true,
          "text": {
            "en": "**ioBroker.ultrahuman** reads health metrics from your Ultrahuman Ring and makes them available as ioBroker objects.",
            "de": "**ioBroker.ultrahuman** liest Gesundheitsdaten von deinem Ultrahuman Ring und stellt sie als ioBroker-Objekte zur Verfügung."
          }
        },
        "_dataHeader": {
          "type": "header",
          "text": {
            "en": "Available data",
            "de": "Verfügbare Daten"
          },
          "size": 6,
          "newLine": true,
          "style": { "marginTop": "16px" }
        },
        "_dataSleep": {
          "type": "staticText",
          "newLine": true,
          "text": {
            "en": "**Sleep:** Efficiency, duration, stages (REM, deep, light), score, cycles",
            "de": "**Schlaf:** Effizienz, Dauer, Phasen (REM, Tief, Leicht), Score, Zyklen"
          }
        },
        "_dataHeart": {
          "type": "staticText",
          "newLine": true,
          "text": {
            "en": "**Heart rate:** Resting, night, average, min/max, trend",
            "de": "**Herzfrequenz:** Ruhe, Nacht, Durchschnitt, Min/Max, Trend"
          }
        },
        "_dataHrv": {
          "type": "staticText",
          "newLine": true,
          "text": {
            "en": "**HRV:** Average, sleep, min/max, trend",
            "de": "**HRV:** Durchschnitt, Schlaf, Min/Max, Trend"
          }
        },
        "_dataSpo2": {
          "type": "staticText",
          "newLine": true,
          "text": {
            "en": "**SpO2:** If supported by your ring",
            "de": "**SpO2:** Falls vom Ring unterstützt"
          }
        },
        "_dataTemp": {
          "type": "staticText",
          "newLine": true,
          "text": {
            "en": "**Skin temperature**",
            "de": "**Hauttemperatur**"
          }
        },
        "_dataActivity": {
          "type": "staticText",
          "newLine": true,
          "text": {
            "en": "**Activity:** Steps, active minutes, movement/recovery index, VO2 max",
            "de": "**Aktivität:** Schritte, aktive Minuten, Bewegungs-/Recovery-Index, VO2 max"
          }
        },
        "_dividerAbout": {
          "type": "divider",
          "newLine": true,
          "style": { "marginTop": "16px", "marginBottom": "16px" }
        },
        "_linksHeader": {
          "type": "header",
          "text": {
            "en": "Links",
            "de": "Links"
          },
          "size": 5,
          "newLine": true
        },
        "_linkGithub": {
          "type": "staticLink",
          "label": {
            "en": "GitHub Repository",
            "de": "GitHub Repository"
          },
          "href": "https://github.com/SmarterPapa/ioBroker.ultrahuman",
          "newLine": true
        },
        "_linkIssues": {
          "type": "staticLink",
          "label": {
            "en": "Report an issue",
            "de": "Problem melden"
          },
          "href": "https://github.com/SmarterPapa/ioBroker.ultrahuman/issues",
          "newLine": true
        },
        "_dividerAuthor": {
          "type": "divider",
          "newLine": true,
          "style": { "marginTop": "16px", "marginBottom": "16px" }
        },
        "_authorHeader": {
          "type": "header",
          "text": {
            "en": "Author",
            "de": "Autor"
          },
          "size": 5,
          "newLine": true
        },
        "_authorText": {
          "type": "staticText",
          "newLine": true,
          "text": {
            "en": "**SmarterPapa** – Smart Home Tips & Inspirations",
            "de": "**SmarterPapa** – Smart Home Tipps & Inspirationen"
          }
        },
        "_authorWebsite": {
          "type": "staticLink",
          "label": "smarterpapa.de",
          "href": "https://smarterpapa.de",
          "newLine": true
        },
        "_licenseText": {
          "type": "staticText",
          "newLine": true,
          "style": { "marginTop": "8px" },
          "text": {
            "en": "**License:** MIT",
            "de": "**Lizenz:** MIT"
          }
        },
        "_supportHeader": {
          "type": "header",
          "text": {
            "en": "Support this project",
            "de": "Unterstütze dieses Projekt"
          },
          "size": 5,
          "newLine": true,
          "style": { "marginTop": "16px" }
        },
        "_supportText": {
          "type": "staticText",
          "newLine": true,
          "style": { "marginBottom": "8px" },
          "text": {
            "en": "If you find this adapter useful, consider buying me a coffee!",
            "de": "Wenn dir dieser Adapter gefällt, kannst du mich gerne auf einen Kaffee einladen!"
          }
        },
        "_kofiLogo": {
          "type": "staticImage",
          "src": "kofi-logo.png",
          "newLine": true,
          "style": { "width": "32px", "height": "32px", "marginRight": "8px", "verticalAlign": "middle", "display": "inline-block" }
        },
        "_kofiLink": {
          "type": "staticLink",
          "label": {
            "en": "Support on Ko-fi",
            "de": "Unterstützen auf Ko-fi"
          },
          "href": "https://ko-fi.com/smarterpapa",
          "button": true,
          "variant": "contained",
          "color": "primary"
        }
      }
    }
  }
}
